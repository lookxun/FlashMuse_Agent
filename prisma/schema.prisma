generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String    @id
  email                      String    @unique
  passwordHash               String?
  nickname                   String?
  phone                      String?
  avatarUrl                  String?
  language                   String    @default("简体中文")
  notifyOnGenerationComplete Boolean   @default(true)
  autoSaveHistory            Boolean   @default(true)
  previewWheelZoom           Boolean   @default(true)
  previewWheelFlip           Boolean   @default(true)
  credits                    Int       @default(1500)
  textCreditRemainder        Float     @default(0)
  disabled                   Boolean   @default(false)
  generalModeEnabled         Boolean   @default(false)
  generatedImageCount        Int       @default(0)
  generatedVideoCount        Int       @default(0)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  lastLoginAt                DateTime?
  lastLoginIp                String?
  lastLoginLocation          String?
  lastLoginUserAgent         String?
  sessions                   Session[]
  workspaceSessions          WorkspaceSession[]
  workspaceMessages          WorkspaceMessage[]
  workspaceWorkflows         WorkspaceWorkflow[]
  workspace                  UserWorkspaceState?
  creditLedgers              CreditLedger[]
  mediaAssets                MediaAsset[]
  userAssetStates            UserAssetState[]
  gptImagePromptOptimizationCases GptImagePromptOptimizationCase[]
}

model CreditSetting {
  id                    String   @id @default("default")
  usdToCnyRate          Float    @default(7.2)
  creditsPerCny         Int      @default(10)
  signupCredits         Int      @default(0)
  chargeText            Boolean  @default(true)
  chargeImage           Boolean  @default(true)
  chargeVideo           Boolean  @default(true)
  chargePromptTool      Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model CreditLedger {
  id               String   @id @default(cuid())
  userId           String
  conversationId   String?
  conversationTitle String?
  workspaceKind    String?
  workspaceId      String?
  requestId        String?
  direction        String   @default("consume")
  kind             String
  label            String?
  model            String?
  credits          Int
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  usd              Float    @default(0)
  cny              Float    @default(0)
  imageCount       Int      @default(0)
  videoCount       Int      @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([direction, createdAt])
  @@index([conversationId])
  @@index([workspaceKind, workspaceId])
  @@unique([requestId, kind])
}

model UserWorkspaceState {
  id        String   @id @default(cuid())
  userId    String   @unique
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MediaAsset {
  id                   String   @id @default(cuid())
  userId               String
  mediaType            String
  url                  String
  normalizedUrl        String
  posterUrl            String?
  thumbnailUrl         String?
  originalUrl          String?
  storagePath          String?
  width                Int?
  height               Int?
  durationSeconds      Int?
  mimeType             String?
  fileSize             Int?
  sourceKind           String
  sourceDetail         String?
  sourcePrompt         String?
  promptSource         String?
  reversePrompt        String?
  model                String?
  modelProvider        String?
  ratio                String?
  resolution           String?
  imageSize            String?
  videoDuration        String?
  generationSettings   Json?
  previewMeta          Json?
  originalFileName     String?
  systemName           String?
  initialName          String?
  initialCategory      String?
  creditLedgerId       String?
  costSource           String?
  chargedUsd           Float    @default(0)
  chargedCny           Float    @default(0)
  chargedCredits       Float    @default(0)
  promptTokens         Float    @default(0)
  completionTokens     Float    @default(0)
  totalTokens          Float    @default(0)
  costShareCount       Int?
  costShareIndex       Int?
  requestId            String?
  conversationId       String?
  messageId            String?
  workflowId           String?
  workflowNodeId       String?
  workspaceKind        String?
  workspaceId          String?
  legacyAssetId        String?
  legacyLibrarySource  String?
  archivedAt           DateTime?
  archiveReason        String?
  duplicateOfMediaAssetId String?
  firstSeenAt          DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userStates           UserAssetState[]

  @@unique([userId, normalizedUrl])
  @@index([userId, mediaType, createdAt])
  @@index([userId, sourceKind, createdAt])
  @@index([creditLedgerId])
  @@index([requestId])
  @@index([conversationId])
  @@index([messageId])
  @@index([workflowId])
  @@index([userId, workspaceKind, createdAt])
  @@index([userId, archivedAt])
}

model UserAssetState {
  id                 String   @id @default(cuid())
  userId             String
  mediaAssetId       String
  currentName        String?
  currentCategory    String
  originalCategory   String?
  previousCategory   String?
  userRenamed        Boolean  @default(false)
  userRecategorized  Boolean  @default(false)
  lockedCategory     Boolean  @default(false)
  sortOrder          Int?
  deletedAt          DateTime?
  purgeAt            DateTime?
  restoredAt         DateTime?
  bytePlusAssetId    String?
  bytePlusAssetGroupId String?
  bytePlusAssetStatus String?
  bytePlusAssetError String?
  bytePlusAssetUpdatedAt DateTime?
  hiddenAt           DateTime?
  hiddenReason       String?
  legacyAssetJson    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaAsset         MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaAssetId])
  @@index([userId, currentCategory, deletedAt, sortOrder])
  @@index([userId, deletedAt, updatedAt])
  @@index([userId, hiddenAt])
}

model GptImagePromptOptimizationCase {
  id              String   @id @default(cuid())
  userId          String
  workflowId      String?
  workflowNodeId  String?
  mediaAssetId    String?
  imageUrl        String
  thumbnailUrl    String?
  sourceModel     String
  optimizerModel  String
  attemptsUsed    Int
  originalPrompt  String
  optimizedPrompt String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workflowId])
  @@index([workflowNodeId])
  @@index([mediaAssetId])
  @@index([sourceModel, createdAt])
}

model WorkspaceSession {
  id            String   @id @default(cuid())
  userId        String
  sessionId     String
  workspaceKind String   @default("conversation")
  title         String
  updatedAt     DateTime
  messagesJson  Json
  summaryJson   Json?
  usageSummary  Json?
  memorySummary Json?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  storedAt      DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([workspaceKind])
  @@index([userId, updatedAt])
  @@index([userId, deletedAt, updatedAt])
}

model WorkspaceWorkflow {
  id            String   @id @default(cuid())
  userId        String
  workflowId    String
  workflowCode  String?
  workspaceKind String   @default("workflow")
  title         String
  nextImageNumber Int    @default(1)
  nextVideoNumber Int    @default(1)
  updatedAt     DateTime
  canvasJson    Json
  usageSummary  Json?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  storedAt      DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workflowId])
  @@index([workspaceKind])
  @@index([userId, updatedAt])
  @@index([userId, deletedAt, updatedAt])
}

model WorkspaceMessage {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String
  messageId   String
  role        String
  content     String
  createdAt   DateTime
  messageJson Json
  storedAt    DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId, messageId])
  @@index([userId, sessionId, createdAt])
  @@index([userId, createdAt])
}

model GenerationEvent {
  id                  String   @id @default(cuid())
  userId              String?
  requestId           String?
  kind                String
  source              String   @default("conversation")
  model               String?
  provider            String?
  status              String
  failureReason       String?
  failureCode         String?
  moderation          Boolean  @default(false)
  durationMs          Int?
  referenceImageCount Int      @default(0)
  referenceVideoCount Int      @default(0)
  referenceAudioCount Int      @default(0)
  createdAt           DateTime @default(now())

  @@unique([requestId, kind])
  @@index([createdAt])
  @@index([kind, status, createdAt])
  @@index([model, createdAt])
  @@index([source, createdAt])
}

model UploadEvent {
  id        String   @id @default(cuid())
  userId    String?
  kind      String   @default("image")
  status    String
  reason    String?
  bytes     Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
}

model GenerationJob {
  id                String    @id @default(cuid())
  userId            String
  requestId         String    @unique
  kind              String
  status            String    @default("queued")
  flow              String?
  creditSource      String?
  model             String?
  provider          String?
  prompt            String?
  settingsJson      Json?
  referenceImages   Json?
  referenceVideos   Json?
  referenceAudios   Json?
  referenceMode     String?
  conversationId    String?
  conversationTitle String?
  messageId         String?
  workflowId        String?
  workflowNodeId    String?
  itemIndex         Int?
  count             Int       @default(1)
  providerTaskId    String?
  reservedNames     Json?
  resultUrls        Json?
  resultDimensions  Json?
  posterUrl         String?
  usageJson         Json?
  creditJson        Json?
  metadataJson      Json?
  extraJson         Json?
  error             String?
  errorCode         String?
  attempts          Int       @default(0)
  leaseAt           DateTime?
  nextRunAt         DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  @@index([status, kind, nextRunAt])
  @@index([userId, status, updatedAt])
  @@index([workflowId])
  @@index([conversationId])
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  activeWorkspaceInstanceId String?
  activeWorkspaceSeenAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
